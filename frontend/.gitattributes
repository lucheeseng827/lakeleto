# Built UI bundle — generated, keep byte-identical (no CRLF conversion).
dist/** -text

# The minified bundle is generated by `npm run build` (rust-embed serves it).
# Mark it generated so its unreviewable diff collapses in review (GitHub) and in
# `git diff` (CLI); regenerate via the build — never hand-edit.
dist/assets/*.js  linguist-generated=true -diff
dist/assets/*.css linguist-generated=true -diff
